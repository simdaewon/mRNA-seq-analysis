library(dplyr)
library(edgeR)
library(ggrepel)
library(ggplot2)

data <- read.delim("data/Q55_rawcounts.txt", row.names = 1)
raw_data <- data[,1:2]

nrow(raw_data) #42844

target_genes <- rownames(data)
original_subset <- data[target_genes, 1:2]

final_table_log2 <- data.frame(
  Gene = target_genes,
  Q55_Norm = data[, 1],
  Control_Norm = data[, 2],
  Log2FC = data[, 1] - data[, 2],
  Avg_Expression = (original_subset[, 1] + original_subset[, 2]) / 2)


non_zero_data <- final_table_log2$Avg_Expression[final_table_log2$Avg_Expression > 0]
length(non_zero_data) #22882

final_table <- final_table_log2 %>% 
  filter(Avg_Expression > 0)

write.csv(final_table,"final_table.csv")

##########################################################################################################################################
pca_input <- final_table %>%
  dplyr::select(Q55_Norm, Control_Norm) %>%
  as.matrix()

rownames(pca_input) <- final_table$Gene

vars <- apply(pca_input, 1, var)
pca_input_clean <- pca_input[vars > 0, ]

cat("전체 유전자:", nrow(pca_input), "\n")
cat("분산이 0이라 제거된 유전자:", sum(vars == 0), "\n")
cat("남은 유전자:", nrow(pca_input_clean), "\n")

rownames(pca_input)[vars == 0]

pca_res <- prcomp(t(pca_input_clean), scale. = TRUE)


pca_df <- as.data.frame(pca_res$x)
pca_df$Sample <- rownames(pca_df)
pca_df$Group <- c("Q55", "Control") 

var_explained <- round(pca_res$sdev^2 / sum(pca_res$sdev^2) * 100, 1)

png(filename = "figure/PCA.png", width = 1200, height = 900, res = 150)
ggplot(pca_df, aes(x = PC1, y = PC2, color = Group)) +
  geom_point(size = 5, alpha = 0.8) +
  theme_bw() +  
  labs(title = "PCA Plot",
       x = paste0("PC1 (", var_explained[1], "%)"),
       y = paste0("PC2 (", var_explained[2], "%)")) +
    scale_color_manual(values = c("Q55" = "#E41A1C", "Control" = "#377EB8")) +
  theme(
    legend.position = "right",
    plot.title = element_text(hjust = 0.5, face = "bold", size = 15),
    aspect.ratio = 1)
dev.off()
#########################################################################################################################################
final_table <- final_table %>%
  mutate(Status = case_when(
    Log2FC > 0.5 ~ "Up",
    Log2FC < -0.5 ~ "Down",
    TRUE ~ "Notsig"))

write.csv(final_table,"data/DEG_table.csv")

final_table <- final_table %>%
  mutate(Status = factor(Status, 
                         levels = c("Up", "Notsig", "Down")))

stats <- final_table %>% 
  group_by(Status) %>% 
  summarise(count = n())


up_label <- paste0("Up (", stats$count[stats$Status == "Up"], ")")
down_label <- paste0("Down (", stats$count[stats$Status == "Down"], ")")
notsig_label <- paste0("Non-DE (", stats$count[stats$Status == "Notsig"], ")")

top_up <- final_table %>%
  filter(Status == "Up") %>%
  arrange(desc(Log2FC)) %>%
  head(20)

top_down <- final_table %>%
  filter(Status == "Down") %>%
  arrange(Log2FC) %>%
  head(20)

label_data <- rbind(top_up, top_down)


my_colors <- c("Up" = "#E41A1C", "Down" = "#377EB8", "Notsig" = "grey80")

png(filename = "figure/Scatter_plot.png", width = 1300, height = 900, res = 150)
ggplot(final_table, aes(x = Control_Norm, y = Q55_Norm, color = Status)) +
  geom_point(alpha = 0.5, size = 1.5) +
  scale_color_manual(values = c("Up" = "#e41a1c", "Notsig" = "grey", "Down" = "#377eb8"), 
                     labels = c(up_label, notsig_label, down_label)) +
  geom_abline(intercept = 0, slope = 1, linetype = "dashed", color = "black", alpha = 0.5) +
  geom_text_repel(data = label_data, 
                  aes(label = Gene),
                  size = 3.5,
                  color = "black",
                  fontface = "bold.italic",
                  max.overlaps = Inf,
                  box.padding = 0.6,
                  point.padding = 0.3,
                  segment.color = "grey50",
                  show.legend = FALSE) +
  theme_bw() +
  labs(title = "Gene Expression Comparison",
       subtitle = "Cut-off: |Log2FC| > 0.5",
       x = "Log2 (Control Normalized Expression)",
       y = "Log2 (Q55 Normalized Expression)",
       color = "Differential Status") +
  theme(
    plot.title = element_text(hjust = 0.5, face = "bold", size = 15),
    plot.subtitle = element_text(hjust = 1, size = 10, face = "italic"),
    legend.position = "right",
    legend.background = element_rect(fill = "white", color = "grey80"),
    aspect.ratio = 1)
dev.off()

