top20_up <- final_table %>%
  filter(Status == "Up") %>%
  filter(!grepl("^LOC", Gene)) %>%
  slice_max(order_by = Log2FC, n = 20)

top20_down <- final_table %>%
  filter(Status == "Down") %>%
  filter(!grepl("^LOC", Gene)) %>%
  slice_min(order_by = Log2FC, n = 20)

top40_combined <- bind_rows(top20_up, top20_down)

annots <- select(org.Hs.eg.db, 
                 keys = top40_combined$Gene, 
                 columns = c("SYMBOL", "ENTREZID", "GENENAME"), 
                 keytype = "SYMBOL")

top40_final <- top40_combined %>%
  left_join(annots, by = c("Gene" = "SYMBOL")) %>%
  dplyr::select(Gene, GENENAME, Log2FC, Status) %>%
  arrange(desc(Log2FC))


write.csv(top40_final, "data/Top40_Description.csv", row.names = FALSE)

