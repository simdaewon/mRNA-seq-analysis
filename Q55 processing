id_to_symbol <- final_table_kegg$Gene
names(id_to_symbol) <- final_table_kegg$EntrezID

convert_ids <- function(id_string) {
  ids <- unlist(strsplit(id_string, "/"))
  symbols <- id_to_symbol[ids]
  return(paste(symbols, collapse = "/"))}

df_kegg_neuro_final <- df_kegg_neuro %>%
  mutate(geneID = sapply(geneID, convert_ids))

write.csv(df_kegg_neuro_final, "GO/KEGG_Neurodegenerative.csv", row.names = FALSE)


