final_table_kegg <- data.frame(
  Gene = rownames(data),
  EntrezID = as.character(data$Entrez.ID),
  Q55_Norm = data[, 1],
  Control_Norm = data[, 2],
  Log2FC = data[, 1] - data[, 2],
  Avg_Expression = (data[, 1] + data[, 2]) / 2) %>%
  filter(Avg_Expression > 0) %>%
  mutate(Status = case_when(
    Log2FC > 0.5 ~ "Up",
    Log2FC < -0.5 ~ "Down",
    TRUE ~ "Notsig"))


up_entrez <- final_table_kegg %>% filter(Status == "Up") %>% pull(EntrezID)
down_entrez <- final_table_kegg %>% filter(Status == "Down") %>% pull(EntrezID)

up_entrez <- na.omit(up_entrez)
down_entrez <- na.omit(down_entrez)

kegg_up <- enrichKEGG(gene = up_entrez, organism = 'hsa', pvalueCutoff = 0.05)
kegg_down <- enrichKEGG(gene = down_entrez, organism = 'hsa', pvalueCutoff = 0.05)

df_kegg_up <- fortify(kegg_up, showCategory = 10) %>% mutate(Direction = "Up-regulated")
df_kegg_down <- fortify(kegg_down, showCategory = 10) %>% mutate(Direction = "Down-regulated")

plot_kegg <- rbind(df_kegg_up, df_kegg_down) %>%
  mutate(Direction = factor(Direction, levels = c("Up-regulated", "Down-regulated")))

png(filename = "figure/KEGG.png", width = 1500, height = 900, res = 150)
ggplot(plot_kegg, aes(x = GeneRatio, y = reorder(Description, GeneRatio))) +
  geom_point(aes(size = Count, color = p.adjust)) + 
  scale_color_gradient(low = "#e41a1c", high = "blue") + 
  facet_grid(. ~ Direction, scales = "free_x") + 
  theme_bw() +
  labs(title = "KEGG Pathway Enrichment Analysis",
       x = "Gene Ratio", 
       y = "KEGG Pathway Description",
       size = "Gene Count",
       color = "Adj. P-value") +
  theme(
    strip.text = element_text(face = "bold", size = 12),
    plot.title = element_text(hjust = 0.5, face = "bold", size = 15),
    axis.text.y = element_text(size = 9, face = "bold"),
    panel.grid.major = element_line(color = "grey95"),
    legend.position = "right")
dev.off()

