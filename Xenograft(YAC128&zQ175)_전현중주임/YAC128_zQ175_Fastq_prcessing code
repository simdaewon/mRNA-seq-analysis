cat << 'EOF' > format_counts.R
# 1. 패키지 자동 설치 및 로드
options(repos = c(CRAN = "https://cloud.r-project.org"))
if (!requireNamespace("BiocManager", quietly = TRUE)) install.packages("BiocManager")
if (!require("dplyr", character.only = TRUE)) install.packages("dplyr")
if (!require("org.Mm.eg.db", character.only = TRUE)) BiocManager::install("org.Mm.eg.db", update=FALSE, ask=FALSE)

suppressPackageStartupMessages(library(org.Mm.eg.db))
suppressPackageStartupMessages(library(dplyr))
 
# 2. 데이터 불러오기 및 열 이름(샘플명) 변경
cat("⏳ 데이터를 불러오고 열 이름을 수정...\n")
counts <- read.table("Final_Counts_Matrix.txt", header=TRUE, check.names=FALSE, stringsAsFactors=FALSE)
colnames(counts)[-1] <- basename(colnames(counts)[-1])
colnames(counts)[-1] <- gsub("_Aligned.sortedByCoord.out.bam", "", colnames(counts)[-1])

# 3. 앙상블 ID를 Symbol과 Entrez ID로 변환
cat("⏳ 유전자 사전을 뒤져서 Symbol과 Entrez ID를 매핑...\n")
counts$Geneid_clean <- gsub("\\.[0-9]+$", "", counts$Geneid)
counts$Symbol <- mapIds(org.Mm.eg.db, keys = counts$Geneid_clean, column = "SYMBOL", keytype = "ENSEMBL", multiVals = "first")
counts$EntrezID <- mapIds(org.Mm.eg.db, keys = counts$Geneid_clean, column = "ENTREZID", keytype = "ENSEMBL", multiVals = "first")

final_counts <- counts %>%
  filter(!is.na(Symbol)) %>%
  select(Symbol, EntrezID, everything()) %>%
  select(-Geneid, -Geneid_clean)

write.table(final_counts, "Final_Counts_Mapped.txt", sep="\t", quote=FALSE, row.names=FALSE)
cat("🎉매핑 및 정리 완료! (저장된 파일명: Final_Counts_Mapped.txt)\n")
EOF

