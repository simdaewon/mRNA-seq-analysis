cat << 'EOF' > rename_and_map.py
import pandas as pd
import mygene
import warnings
warnings.filterwarnings('ignore')

print("⏳ 1. 데이터를 불러오고 지저분한 샘플명을 정리...")
df = pd.read_csv("Final_Counts_Matrix.txt", sep="\t")

# 열 이름(경로 및 확장자) 깔끔하게 자르기
new_cols = []
for col in df.columns:
    if "Aligned.sortedByCoord" in col:
        new_col = col.split("/")[-1].replace("_Aligned.sortedByCoord.out.bam", "")
        new_cols.append(new_col)
    else:
        new_cols.append(col)
df.columns = new_cols

print("⏳ 2. 앙상블 ID를 유전자 이름(Symbol)과 Entrez ID로 변환 중")
# 앙상블 ID 뒤에 붙은 .1, .2 같은 버전 꼬리표 떼기
df['Ensembl_clean'] = df['Geneid'].str.split('.').str[0]

# mygene 모듈로 DB 검색
mg = mygene.MyGeneInfo()
res = mg.querymany(df['Ensembl_clean'].tolist(), scopes='ensembl.gene', fields='symbol,entrezgene', species='mouse', as_dataframe=True, verbose=False)

# 결과 정리
res = res[['symbol', 'entrezgene']].reset_index()
res.rename(columns={'query': 'Ensembl_clean', 'symbol': 'Symbol', 'entrezgene': 'EntrezID'}, inplace=True)
res = res[~res['Ensembl_clean'].duplicated(keep='first')]

print("⏳ 3. 기존 앙상블 ID를 삭제하고 최종 파일 생성...")
final_df = pd.merge(res, df, on='Ensembl_clean', how='inner')
final_df.drop(columns=['Ensembl_clean', 'Geneid'], inplace=True, errors='ignore')

# 맨 앞으로 순서 당기고 저장
cols = ['Symbol', 'EntrezID'] + [c for c in final_df.columns if c not in ['Symbol', 'EntrezID']]
final_df = final_df[cols]
final_df.dropna(subset=['Symbol'], inplace=True) # Symbol 없는 찌꺼기 제거

final_df.to_csv("Final_Counts_Mapped.txt", sep="\t", index=False)
print("🎉 완벽하게 변환 완료! (저장된 파일명: Final_Counts_Mapped.txt)")
EOF

python rename_and_map.py

