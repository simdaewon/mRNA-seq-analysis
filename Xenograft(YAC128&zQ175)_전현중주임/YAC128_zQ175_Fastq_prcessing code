cat << 'EOF' > pipeline.sh
#!/bin/bash

# ==========================================
# 1. 경로 및 환경 설정
# ==========================================
FASTQ_DIR="/home/won/Bulk_RNA_seq/Fastq/YAC128_zQ175_전현중_20260312"
RESULT_DIR="/home/won/Bulk_RNA_seq/Results"
STAR_INDEX="/home/won/Bulk_RNA_seq/reference/STAR_index_mouse" 
GTF_FILE="/home/won/Bulk_RNA_seq/reference/raw_data/Mus_musculus.GRCm39.110.gtf" 

THREADS=22
mkdir -p ${RESULT_DIR}
BAM_LIST=""

# ==========================================
# 2. 샘플별 Trimming & Mapping Loop
# ==========================================
SAMPLES=$(ls ${FASTQ_DIR}/*_1.fastq.gz | xargs -n 1 basename | sed 's/_1.fastq.gz//')

for SAMPLE in $SAMPLES; do
    echo "=================================================="
    echo " 🚀 Processing Sample: $SAMPLE "
    echo "=================================================="
    
    SAMPLE_OUT="${RESULT_DIR}/${SAMPLE}"
    mkdir -p ${SAMPLE_OUT}

    echo "[Step A] Trimming with fastp..."
    fastp -i ${FASTQ_DIR}/${SAMPLE}_1.fastq.gz \
          -I ${FASTQ_DIR}/${SAMPLE}_2.fastq.gz \
          -o ${SAMPLE_OUT}/${SAMPLE}_trimmed_1.fastq.gz \
          -O ${SAMPLE_OUT}/${SAMPLE}_trimmed_2.fastq.gz \
          -h ${SAMPLE_OUT}/${SAMPLE}_fastp.html \
          -j ${SAMPLE_OUT}/${SAMPLE}_fastp.json \
          -w ${THREADS}

    echo "[Step B] Alignment with STAR..."
    STAR --runThreadN ${THREADS} \
         --genomeDir ${STAR_INDEX} \
         --readFilesIn ${SAMPLE_OUT}/${SAMPLE}_trimmed_1.fastq.gz ${SAMPLE_OUT}/${SAMPLE}_trimmed_2.fastq.gz \
         --readFilesCommand zcat \
         --outFileNamePrefix ${SAMPLE_OUT}/${SAMPLE}_ \
         --outSAMtype BAM SortedByCoordinate

    BAM_LIST="${BAM_LIST} ${SAMPLE_OUT}/${SAMPLE}_Aligned.sortedByCoord.out.bam"
done

# ==========================================
# 3. Final Count Matrix 생성
# ==========================================
echo "=================================================="
echo " 📊 Generating Final Count Matrix "
echo "=================================================="

echo "[Step C] Counting with featureCounts..."
featureCounts -T ${THREADS} \
              -p \
              -a ${GTF_FILE} \
              -o ${RESULT_DIR}/Raw_merged_counts.txt \
              ${BAM_LIST}

cut -f1,7- ${RESULT_DIR}/Raw_merged_counts.txt | sed '1d' > ${RESULT_DIR}/Final_Counts_Matrix.txt

echo " 🎉 모든 분석이 완료! "
EOF

chmod +x pipeline.sh
nohup ./pipeline.sh &
tail -f nohup.out

head /home/won/Bulk_RNA_seq/Results/Final_Counts_Matrix.txt | column -t


###############################IGV file indexing#################################

