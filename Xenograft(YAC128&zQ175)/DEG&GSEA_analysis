design_y_edgeR <- model.matrix(~ 0 + group, data = sampleinfo_y)
colnames(design_y_edgeR) <- gsub("group", "", colnames(design_y_edgeR))

if(n.sv_y > 0) {
  colnames(svobj_y$sv) <- paste0("SV", 1:n.sv_y)
  design_y_edgeR <- cbind(design_y_edgeR, svobj_y$sv)
}


dge_y <- estimateDisp(dge_y, design_y_edgeR)

fit_y_edgeR <- glmQLFit(dge_y, design_y_edgeR)


cont_matrix_y_edgeR <- makeContrasts(
  TG_vs_WT = Y_TG_VC - Y_WT_VC,      
  NPC_vs_TG = Y_TG_NPC - Y_TG_VC,    
  levels = design_y_edgeR)


qlf_TG_vs_WT <- glmQLFTest(fit_y_edgeR, contrast = cont_matrix_y_edgeR[, "TG_vs_WT"])
res_edgeR_TG_vs_WT <- topTags(qlf_TG_vs_WT, n = Inf)$table

qlf_NPC_vs_TG <- glmQLFTest(fit_y_edgeR, contrast = cont_matrix_y_edgeR[, "NPC_vs_TG"])
res_edgeR_NPC_vs_TG <- topTags(qlf_NPC_vs_TG, n = Inf)$table

write.csv(res_edgeR_TG_vs_WT, "data/DEG_YAC128_TG_vs_WT.csv", row.names = TRUE)
write.csv(res_edgeR_NPC_vs_TG, "data/DEG_YAC128_NPC_vs_TG.csv", row.names = TRUE)

