extract_top40_deg <- function(deg_data, save_path) {
  df <- as.data.frame(deg_data)
  df$Symbol <- rownames(df)
  df_filtered <- df %>%
    filter(PValue < 0.05) %>%
    filter(!grepl("^Gm[0-9]+", Symbol)) %>%
    filter(!grepl("Rik$", Symbol))
  top_up <- df_filtered %>%
    filter(logFC > 0) %>%
    arrange(desc(logFC)) %>%
    head(20) %>%
    mutate(Status = "Up")
    top_down <- df_filtered %>%
    filter(logFC < 0) %>%
    arrange(logFC) %>%
    head(20) %>%
    arrange(desc(logFC)) %>%
    mutate(Status = "Down")
  top40_combined <- bind_rows(top_up, top_down)
  top40_combined$GENENAME <- mapIds(org.Mm.eg.db,
                                    keys = top40_combined$Symbol,
                                    column = "GENENAME",
                                    keytype = "SYMBOL",
                                    multiVals = "first")
  top40_combined <- top40_combined %>%
    dplyr::select(Symbol, GENENAME, logFC, Status) 
  write.csv(top40_combined, save_path, row.names = FALSE)
  return(top40_combined)}


