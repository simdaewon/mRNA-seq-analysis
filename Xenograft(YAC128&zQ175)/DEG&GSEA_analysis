volcano_data_y <- as.data.frame(res_edgeR_z_TG_vs_WT)
volcano_data_y$Symbol <- rownames(volcano_data_y)

volcano_data_y <- volcano_data_y %>%
  filter(!grepl("^Gm[0-9]+", Symbol)) %>%
  filter(!grepl("Rik$", Symbol))


logFC_cutoff <- 1
pval_cutoff  <- 0.05

volcano_data_y <- volcano_data_y %>%
  mutate(
    Significance = case_when(
      logFC > logFC_cutoff & PValue < pval_cutoff ~ "Up",
      logFC < -logFC_cutoff & PValue < pval_cutoff ~ "Down",
      TRUE ~ "Not Significant"
    )
  )

counts <- table(volcano_data_y$Significance)

count_up <- ifelse(is.na(counts["Up"]), 0, counts["Up"])
count_down <- ifelse(is.na(counts["Down"]), 0, counts["Down"])
count_ns <- ifelse(is.na(counts["Not Significant"]), 0, counts["Not Significant"])

label_up <- paste0("Up (", count_up, ")")
label_down <- paste0("Down (", count_down, ")")
label_ns <- paste0("Not Significant (", count_ns, ")")

top_up <- volcano_data_y %>% 
  filter(Significance == "Up") %>% 
  arrange(PValue) %>% 
  head(15)

top_down <- volcano_data_y %>% 
  filter(Significance == "Down") %>% 
  arrange(PValue) %>% 
  head(15)

top_genes <- bind_rows(top_up, top_down)

max_x <- max(abs(volcano_data_y$logFC), na.rm = TRUE) * 1.05

p_volcano_y <- ggplot(volcano_data_y, aes(x = logFC, y = -log10(PValue), color = Significance)) +
  geom_point(alpha = 0.8, size = 2) +
  scale_color_manual(
    values = c("Up" = "#E41A1C", "Down" = "#377EB8", "Not Significant" = "grey80"),
    labels = c("Up" = label_up, "Down" = label_down, "Not Significant" = label_ns)
  ) +
  scale_x_continuous(limits = c(-max_x, max_x)) +
  geom_vline(xintercept = c(-logFC_cutoff, logFC_cutoff), linetype = "dashed", color = "black", alpha = 0.5) +
  geom_hline(yintercept = -log10(pval_cutoff), linetype = "dashed", color = "black", alpha = 0.5) +
  geom_text_repel(data = top_genes, aes(label = Symbol), 
                  size = 4, color = "black", fontface = "italic",
                  box.padding = 0.5, max.overlaps = Inf) +
  theme_bw() +
  labs(
    title = "zQ175 (TG vs WT)",
    subtitle = paste0("Cutoff: |logFC| > ", logFC_cutoff, " & P-value < ", pval_cutoff),
    x = "Log2 Fold Change",
    y = "-Log10(P-value)" 
  ) +
  theme(
    plot.title = element_text(hjust = 0.5, face = "bold", size = 16),
    plot.subtitle = element_text(hjust = 1, face = "italic", color = "grey20"), 
    legend.position = "right",
    legend.title = element_blank()
  )

png(filename = "figure/Volcano_zQ175_TG_vs_WT_v1.png", width = 1500, height = 1000, res = 150)
print(p_volcano_y)
dev.off()

