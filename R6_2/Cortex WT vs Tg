library(clusterProfiler)
library(org.Mm.eg.db)
library(enrichplot)

up_genes <- final_table %>% filter(Status == "Up") %>% pull(Gene)
down_genes <- final_table %>% filter(Status == "Down") %>% pull(Gene)


